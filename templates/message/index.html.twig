{% extends 'base.html.twig' %}

{% block title %}Message{% endblock %}

{% block body %}

    <section class="">
        {% for conversation in conversations %}
            <section>
                <div>
                    <img src="" alt="">

                </div>
                <div>
                    {% for user in conversation.otherUsers %}
                        <p>
                            <a href="{{ path('app_message_show',{'id':conversation.conversation.id}) }}">{{ user.firstName }}</a>
                        </p>
                    {% endfor %}
                </div>
                <div>
                    <p></p>
                </div>
            </section>
        {% endfor %}
    </section>


{% endblock %}
